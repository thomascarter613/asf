# Agentic Software Foundry local development environment.
# Copy this file to .env for local use.
#
# Never commit .env.

ASF_ENV=local

# ---------------------------------------------------------------------------
# Container image tags
# ---------------------------------------------------------------------------
#
# These tags are intentionally centralized so the image pinning policy can be
# hardened later without rewriting Compose service definitions.

POSTGRES_IMAGE=postgres:17-alpine
MONGODB_IMAGE=mongodb/mongodb-community-server:8.0.21-ubi9-slim
QDRANT_IMAGE=qdrant/qdrant:v1.17.1

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=asf
POSTGRES_USER=asf
POSTGRES_PASSWORD=asf_local_password

DATABASE_URL=postgresql://asf:asf_local_password@localhost:5432/asf

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=asf
MONGODB_ROOT_USERNAME=asf
MONGODB_ROOT_PASSWORD=asf_local_password

MONGODB_URI=mongodb://asf:asf_local_password@localhost:27017/asf?authSource=admin

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------

QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# ---------------------------------------------------------------------------
# Object storage
# ---------------------------------------------------------------------------
#
# Object storage is intentionally deferred to a follow-up commit.
# The architecture expects local object storage, but the MinIO container choice
# should be made explicitly because of the current upstream container publishing
# and security-release situation.
