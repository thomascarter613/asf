{
  "name": "agentic-software-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Repository-governed framework for disciplined AI-assisted software development.",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "verify": "bun run verify:repo && bun run verify:work-packets",
    "verify:repo": "bash tools/check-repo-contract.sh",
    "verify:work-packets": "bun run work-packet validate-repo",
    "test": "bun test",
    "test:work-packet-core": "bun test packages/work-packet-core",
    "test:work-packet-cli": "bun test packages/work-packet-cli",
    "work-packet": "bun run packages/work-packet-cli/src/index.ts"
  }
}