{
  "schemaVersion": "0.1.0",
  "description": "Required frontmatter fields for meaningful Markdown documents.",
  "requiredFields": [
    "title",
    "description",
    "status",
    "version",
    "created",
    "updated",
    "owner",
    "canonical",
    "tags"
  ],
  "allowedStatuses": [
    "draft",
    "active",
    "accepted",
    "superseded",
    "archived"
  ],
  "versionPattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
  "datePattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
  "adr": {
    "pathPrefix": "docs/adr/ADR-",
    "requiredFields": [
      "adr",
      "decision_date",
      "supersedes",
      "superseded_by"
    ],
    "requiredStatus": "accepted"
  },
  "templates": {
    "requiredField": "template"
  },
  "exemptPaths": []
}