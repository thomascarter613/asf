        "Source Traceability",
        "Usage Instructions",
        "Lifecycle Log"
      ]
    },
    {
      "path": ".charon/daedalus/handoff-packets/handoff-packet-template.md",
      "requiredSections": [
        "Metadata",
        "Project Identity",
        "Summary",
        "Completed Work",
        "Changed Files",
        "Verification Status",
        "Documentation Status",
        "Commit Status",
        "Active Work Packet",
        "Open Risks or Blockers",
        "Memory Candidates Produced",
        "Context for Next Session",
        "Next Recommended Action",
        "New-Session Bootstrap Guidance",
        "Lifecycle Log"
      ]
    },
    {
      "path": ".sdlc/verification/verification-record-template.md",
      "requiredSections": [
        "Metadata",
        "Purpose",
        "Verification Scope",
        "Commands or Checks",
        "Summary Result",
        "Evidence",
        "Failures",
        "Skipped or Not-Run Checks",
